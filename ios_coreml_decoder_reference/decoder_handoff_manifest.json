      "8": "b_x",
      "9": "b_y",
      "10": "b_score",
      "11": "c_disc_bottom_x",
      "12": "c_disc_bottom_y",
      "13": "c_disc_bottom_score"
    }
  },
  "decoder": {
    "language": "Swift",
    "minimum_dependencies": ["Foundation", "CoreGraphics", "CoreML"],
    "default_confidence_threshold": 0.25,
    "debug_confidence_threshold": 0.05,
    "default_iou_threshold": 0.45,
    "max_detections": 20,
    "resize_modes": ["stretch", "scaleFitLetterbox", "centerCrop"]
